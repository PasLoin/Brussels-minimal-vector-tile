{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/maplibre-style-minimal.schema.json",
  "title": "Minimal MapLibre style document",
  "description": "Validates the repository's MapLibre style document shape before deeper PMTiles source-layer checks run.",
  "type": "object",
  "required": ["version", "sources", "layers"],
  "properties": {
    "version": {
      "const": 8
    },
    "name": {
      "type": "string"
    },
    "glyphs": {
      "type": "string"
    },
    "sprite": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["vector", "raster", "raster-dem", "geojson", "image", "video", "canvas"]
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "attribution": {
            "type": "string"
          },
          "tiles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "minzoom": {
            "type": "number",
            "minimum": 0
          },
          "maxzoom": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["background", "fill", "line", "symbol", "circle", "heatmap", "fill-extrusion", "raster", "hillshade", "sky"]
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "source-layer": {
            "type": "string",
            "minLength": 1
          },
          "layout": {
            "type": "object"
          },
          "paint": {
            "type": "object"
          },
          "filter": {
            "type": "array"
          },
          "minzoom": {
            "type": "number",
            "minimum": 0
          },
          "maxzoom": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
