{
  "version": 8,
  "name": "Brussels Ultimate",
  "metadata": {
    "maputnik:renderer": "mlgljs",
    "description": "Brussels Ultimate Vector tiles style"
  },
  "sources": {
    "brussels": {
      "type": "vector",
      "url": "https://pmtiles.duckdns.org/tiles/brussels_ultimate_v2.json",
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {"background-color": "#f2ede3"}
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "brussels",
      "source-layer": "landuse",
      "filter": [
        "any",
        ["==", ["get", "landuse"], "residential"],
        ["==", ["get", "landuse"], "garages"]
      ],
      "paint": {"fill-color": "#ede8d8", "fill-opacity": 0.85}
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "brussels",
      "source-layer": "landuse",
      "filter": [
        "any",
        ["==", ["get", "landuse"], "industrial"],
        ["==", ["get", "landuse"], "commercial"],
        ["==", ["get", "landuse"], "retail"]
      ],
      "paint": {"fill-color": "#ddd6c4", "fill-opacity": 0.9}
    },
    {
      "id": "landuse-transport",
      "type": "fill",
      "source": "brussels",
      "source-layer": "landuse",
      "filter": [
        "any",
        ["==", ["get", "landuse"], "railway"],
        ["==", ["get", "landuse"], "traffic_island"]
      ],
      "paint": {"fill-color": "#ccc4b2", "fill-opacity": 0.8}
    },
    {
      "id": "landuse-water",
      "type": "fill",
      "source": "brussels",
      "source-layer": "landuse",
      "filter": ["==", ["get", "landuse"], "basin"],
      "paint": {"fill-color": "#b8d4e8", "fill-opacity": 0.9}
    },
    {
      "id": "green-forest",
      "type": "fill",
      "source": "brussels",
      "source-layer": "green",
      "filter": [
        "any",
        ["==", ["get", "landuse"], "forest"],
        ["==", ["get", "natural"], "wood"]
      ],
      "paint": {"fill-color": "#a8c990", "fill-opacity": 0.75}
    },
    {
      "id": "green-scrub",
      "type": "fill",
      "source": "brussels",
      "source-layer": "green",
      "filter": ["==", ["get", "natural"], "scrub"],
      "paint": {"fill-color": "#bed8a0", "fill-opacity": 0.65}
    },
    {
      "id": "green-grass",
      "type": "fill",
      "source": "brussels",
      "source-layer": "green",
      "filter": [
        "any",
        ["==", ["get", "landuse"], "grass"],
        ["==", ["get", "landuse"], "meadow"],
        ["==", ["get", "natural"], "grassland"]
      ],
      "paint": {
        "fill-color": "rgba(125, 3, 39, 1)",
        "fill-opacity": 0.7,
        "fill-outline-color": "rgba(193, 11, 38, 1)"
      }
    },
    {
      "id": "green-park",
      "type": "fill",
      "source": "brussels",
      "source-layer": "green",
      "filter": [
        "any",
        ["==", ["get", "leisure"], "park"],
        ["==", ["get", "leisure"], "garden"],
        ["==", ["get", "leisure"], "nature_reserve"]
      ],
      "paint": {"fill-color": "rgba(196, 241, 168, 1)", "fill-opacity": 0.75}
    },
    {
      "id": "green-outline",
      "type": "line",
      "source": "brussels",
      "source-layer": "green",
      "filter": [
        "any",
        ["==", ["get", "leisure"], "park"],
        ["==", ["get", "leisure"], "garden"],
        ["==", ["get", "landuse"], "forest"],
        ["==", ["get", "natural"], "wood"]
      ],
      "paint": {"line-color": "#8eba70", "line-width": 0.6, "line-opacity": 0.6}
    },
    {
      "id": "buildings-fill",
      "type": "fill",
      "source": "brussels",
      "source-layer": "buildings",
      "paint": {"fill-color": "#ddd5c5", "fill-opacity": 0.9}
    },
    {
      "id": "buildings-outline",
      "type": "line",
      "source": "brussels",
      "source-layer": "buildings",
      "paint": {"line-color": "#b8ae9c", "line-width": 0.6}
    },
    {
      "id": "buildings-3d",
      "type": "fill-extrusion",
      "source": "brussels",
      "source-layer": "buildings_parts",
      "paint": {
        "fill-extrusion-color": [
          "interpolate",
          ["linear"],
          ["coalesce", ["get", "building:levels"], 2],
          1,
          "#d4c8b4",
          4,
          "#c8baa4",
          8,
          "#bca898"
        ],
        "fill-extrusion-height": [
          "coalesce",
          ["get", "height"],
          ["*", ["coalesce", ["get", "building:levels"], 2], 3.2],
          6
        ],
        "fill-extrusion-base": ["coalesce", ["get", "min_height"], 0],
        "fill-extrusion-opacity": 0.72
      }
    },
    {
      "id": "infra-casing",
      "type": "line",
      "source": "brussels",
      "source-layer": "infra",
      "filter": [
        "any",
        ["==", ["get", "highway"], "primary"],
        ["==", ["get", "highway"], "trunk"]
      ],
      "paint": {
        "line-color": "#b08850",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2.5, 16, 8],
        "line-opacity": 0.35
      }
    },
    {
      "id": "infra-major",
      "type": "line",
      "source": "brussels",
      "source-layer": "infra",
      "filter": [
        "any",
        ["==", ["get", "highway"], "primary"],
        ["==", ["get", "highway"], "secondary"],
        ["==", ["get", "highway"], "trunk"]
      ],
      "paint": {
        "line-color": "#c4a46c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1.2, 16, 5],
        "line-opacity": 0.9
      }
    },
    {
      "id": "infra-minor",
      "type": "line",
      "source": "brussels",
      "source-layer": "infra",
      "filter": [
        "any",
        ["==", ["get", "highway"], "residential"],
        ["==", ["get", "highway"], "service"],
        ["==", ["get", "highway"], "tertiary"],
        ["==", ["get", "highway"], "unclassified"]
      ],
      "paint": {
        "line-color": "#ccc0a8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 3],
        "line-opacity": 0.85
      }
    },
    {
      "id": "cycling-casing",
      "type": "line",
      "source": "brussels",
      "source-layer": "cycling",
      "paint": {
        "line-color": "#4a90d9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2.5, 16, 6],
        "line-opacity": 0.18
      }
    },
    {
      "id": "cycling-line",
      "type": "line",
      "source": "brussels",
      "source-layer": "cycling",
      "paint": {
        "line-color": [
          "match",
          ["get", "cycleway"],
          "lane",
          "#2a78c8",
          "track",
          "#1a62a8",
          "#3a86d4"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 3.5],
        "line-dasharray": [3, 2],
        "line-opacity": 0.85
      }
    },
    {
      "id": "pedestrian-casing",
      "type": "line",
      "source": "brussels",
      "source-layer": "pedestrian",
      "paint": {
        "line-color": "#8a6e4e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 2, 18, 7],
        "line-opacity": 0.15
      }
    },
    {
      "id": "pedestrian-line",
      "type": "line",
      "source": "brussels",
      "source-layer": "pedestrian",
      "filter": ["!=", ["get", "highway"], "steps"],
      "paint": {
        "line-color": [
          "match",
          ["get", "highway"],
          "footway",
          "#c08040",
          "path",
          "#b07030",
          "#b87840"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 18, 3],
        "line-opacity": 0.8
      }
    },
    {
      "id": "pedestrian-steps",
      "type": "line",
      "source": "brussels",
      "source-layer": "pedestrian",
      "filter": ["==", ["get", "highway"], "steps"],
      "paint": {
        "line-color": "#a85a28",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 18, 4],
        "line-dasharray": [1, 1.2],
        "line-opacity": 0.8
      }
    },
    {
      "id": "accessibility-halo",
      "type": "circle",
      "source": "brussels",
      "source-layer": "accessibility",
      "paint": {
        "circle-color": "#e03020",
        "circle-radius": 7,
        "circle-opacity": 0.1
      }
    },
    {
      "id": "accessibility-dot",
      "type": "circle",
      "source": "brussels",
      "source-layer": "accessibility",
      "filter": ["all", ["==", "name", ""]],
      "paint": {
        "circle-color": "#e03020",
        "circle-radius": 3.5,
        "circle-stroke-width": 1.2,
        "circle-stroke-color": "#fffdf7",
        "circle-opacity": 0.9
      }
    },
    {
      "id": "furniture-halo",
      "type": "circle",
      "source": "brussels",
      "source-layer": "furniture",
      "paint": {
        "circle-color": "#d4820a",
        "circle-radius": 8,
        "circle-opacity": 0.1
      }
    },
    {
      "id": "furniture-dot",
      "type": "circle",
      "source": "brussels",
      "source-layer": "furniture",
      "paint": {
        "circle-color": [
          "match",
          ["get", "amenity"],
          "bench",
          "#d4820a",
          "waste_basket",
          "#8c6820",
          "bicycle_parking",
          "#2a78c8",
          "drinking_water",
          "#1a9abf",
          "toilets",
          "#7a4ab0",
          "shelter",
          "#3a8a3a",
          "#c07818"
        ],
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 13, 3, 18, 6],
        "circle-stroke-width": 1.4,
        "circle-stroke-color": "#fffdf7",
        "circle-opacity": 0.95
      }
    },
    {
      "id": "poi-halo",
      "type": "circle",
      "source": "brussels",
      "source-layer": "poi",
      "paint": {
        "circle-color": "#7c4ec4",
        "circle-radius": 8,
        "circle-opacity": 0.08
      }
    },
    {
      "id": "poi-dot",
      "type": "circle",
      "source": "brussels",
      "source-layer": "poi",
      "paint": {
        "circle-color": "#7c4ec4",
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 13, 3, 18, 5.5],
        "circle-stroke-width": 1.2,
        "circle-stroke-color": "#fffdf7",
        "circle-opacity": 0.9
      }
    }
  ],
  "id": "n4fdwh5h4"
}
